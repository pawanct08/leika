# ─── L.E.I.K.A. Backend — Environment Variables ───────────────────────────
# Copy this file to .env and fill in the values you need.
# All variables are OPTIONAL unless marked [REQUIRED for X].

# ─── CORE ─────────────────────────────────────────────────────────────────
PORT=3000


# ─── ANTHROPIC CLAUDE ─────────────────────────────────────────────────────
# Enables Claude-powered routing, chat, and vision analysis.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# Model used for main chat (default: claude-3-5-sonnet-20241022)
CLAUDE_MODEL=claude-3-5-sonnet-20241022


# ─── OPENAI ───────────────────────────────────────────────────────────────
# Enables real text-embedding-3-small embeddings + Whisper transcription.
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx


# ─── TAVILY SEARCH ─────────────────────────────────────────────────────────
# Enables real-time web search for skills (web-search, news, stocks).
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxx


# ─── ELEVENLABS TTS ────────────────────────────────────────────────────────
# Enables high-quality voice synthesis. Falls back to browser TTS if unset.
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxx
# Voice ID (default = Rachel). Browse voices at https://api.elevenlabs.io/v1/voices
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM


# ─── OPENWEATHERMAP ────────────────────────────────────────────────────────
# Enables real-time weather for the weather skill + proactive storm alerts.
OPENWEATHER_API_KEY=xxxxxxxxxxxxxxxxxxxx
# Default city for weather queries and cron alerts.
WEATHER_CITY=New Delhi


# ─── HOME ASSISTANT ────────────────────────────────────────────────────────
# Enables the smart-home skill to control real devices.
HASS_URL=http://homeassistant.local:8123
# Long-lived access token from: Profile > Long-Lived Access Tokens
HASS_TOKEN=xxxxxxxxxxxxxxxxxxxx


# ─── NEO4J GRAPH DATABASE ─────────────────────────────────────────────────
# Subconscious knowledge graph.  Leave as-is for local Neo4j Desktop.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=leika


# ─── PINECONE VECTOR DATABASE ─────────────────────────────────────────────
# Semantic memory / Internet Archive index.
PINECONE_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
